generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum untuk melacak status permintaan
enum RequestStatus {
  OPEN // Permintaan masih dibuka
  FULFILLED // Permintaan sudah terpenuhi
  CANCELLED
  REQUESTED
  FULFILLING
  CONFIRMED // Permintaan dibatalkan
}

model termsCondition {
  id        String   @id @default(cuid())
  userid    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id           String   @id @default(cuid())
  notification String
  uuid         String?
  userid       String
  notifType    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relasi ke Donation yang lama bisa dihapus jika tidak dipakai lagi
  // donations         Donation[]
}

// Model untuk Campaign (TIDAK BERUBAH)
model Campaign {
  id                String   @id @default(cuid())
  title             String
  description       String
  targetAmount      Float
  currentAmount     Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  creatorFirebaseId String

  // Relasi ke Donation yang lama bisa dihapus jika tidak dipakai lagi
  // donations         Donation[]
}

// --- MODEL BARU UNTUK PERMINTAAN DONASI BARANG ---
model DonationRequest {
  id String @id @default(cuid())

  // Info Requestor
  requestorFirebaseId String // ID dari Firebase Auth
  requestorName       String // Nama pemohon
  donationType        String?
  detailBarang        String?
  alasanDonasi        String?
  // Info Lokasi
  locationDescription String // Alamat atau deskripsi lokasi
  latitude            Float? // Opsional
  longitude           Float? // Opsional
  city                String? // Kota (opsional)
  // Info Donasi
  description         String // Penjelasan kenapa butuh donasi
  itemType            String // Jenis barang yang dibutuhkan (mis: "Pakaian", "Beras")
  itemWeight          Float? // Perkiraan berat barang (opsional)
  weightUnit          String? // Satuan berat (mis: "kg", "liter") (opsional)

  // Status & Timestamps
  status    RequestStatus @default(OPEN) // Status default adalah OPEN
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  expiredAt DateTime?

  photoDonations PhotoDonation[]

  // Relasi ke fulfillment
  fulfillments         DonationFulfillment[]
  chatRooms            ChatRoom[]
  donationRequestments DonationRequestment[]

  @@unique([detailBarang, itemType, alasanDonasi, requestorFirebaseId])
}

model PhotoDonation {
  id                String          @id @default(cuid())
  imageFile         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  donationRequestId String
  donationRequest   DonationRequest @relation(fields: [donationRequestId], references: [id])
}

// --- MODEL BARU UNTUK MENCATAT PEMENUHAN DONASI (DARI DONATUR) ---
model DonationFulfillment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Info Donatur
  donorFirebaseId        String // ID Firebase dari donatur
  donorRequestFirebaseId String?
  donorName              String // Nama donatur
  donorNotes             String // Catatan dari donatur (opsional)
  latitude               Float? // Lokasi donatur (opsional)
  longitude              Float? // Lokasi donatur (opsional)
  address                String? // Alamat donatur (opsional)
  city                   String?
  status                 RequestStatus   @default(FULFILLING) // Status default adalah OPEN
  // Kota donatur (opsional)
  // Relasi ke Permintaan Donasi yang dipenuhi
  // Ini akan menghubungkan donasi ini ke permintaan spesifik
  donationRequestId      String
  donationRequest        DonationRequest @relation(fields: [donationRequestId], references: [id])
  chatRoom               ChatRoom?

  @@unique([donationRequestId, donorNotes, donorFirebaseId, donorName])
}

model DonationRequestment {
  id                String          @id @default(cuid())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  requestorId       String // ID Firebase dari donatur
  donorFirebaseId   String?
  status            RequestStatus   @default(REQUESTED) // Status default adalah OPEN
  donorName         String // Nama donatur
  reason            String // Catatan dari donatur (opsional)
  latitude          Float? // Lokasi donatur (opsional)
  longitude         Float? // Lokasi donatur (opsional)
  address           String? // Alamat donatur (opsional)
  city              String? // Kota donatur (opsional)
  donationRequestId String
  donationRequest   DonationRequest @relation(fields: [donationRequestId], references: [id])
  chatRoom          ChatRoom?

  @@unique([donationRequestId, requestorId, reason, donorName])
}

model Token {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id        String  @id @default(uuid())
  name      String?
  email     String? @unique
  role      String?
  password  String?
  isActive  Boolean @default(false)
  isDonate  Boolean @default(false)
  isPhotoId Boolean @default(false)

  identificationNumber String?
  photoKtp             String?
  // Nama relasi di sini harus sama dengan yang ada di model Chat
  sentMessages         Chat[]  @relation("UserSentChats")
  readMessages         Chat[]  @relation("UserReadBy")

  rooms     ChatRoomMember[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @default(now())
}

model ChatRoom {
  id     String @id @default(uuid())
  roomId String @unique

  // Relasi ke DonationRequest
  donationRequestId String
  donation          DonationRequest @relation(fields: [donationRequestId], references: [id], onDelete: Cascade)

  // Relasi balik ke Fulfillment
  fulfillmentId String?              @unique
  fulfillment   DonationFulfillment? @relation(fields: [fulfillmentId], references: [id])

  // Relasi balik ke Requestment
  requestmentId String?              @unique
  requestment   DonationRequestment? @relation(fields: [requestmentId], references: [id])

  isActive    Boolean  @default(true)
  lastMessage String   @default("")
  lastSeen    DateTime @default(now())
  unreadCount Int      @default(0)

  members ChatRoomMember[]
  chats   Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hapus @@unique([donationRequestId]) jika ingin banyak chat per donasi
}

model ChatRoomMember {
  userId String
  roomId String

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@id([userId, roomId])
  @@index([roomId])
}

model Chat {
  id String @id @default(uuid())

  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // Pengirim: Menggunakan nama relasi "UserSentChats" agar cocok dengan User
  senderId String
  sender   User   @relation("UserSentChats", fields: [senderId], references: [id], onDelete: Cascade)

  message String

  // Pembaca: Menggunakan nama relasi "UserReadBy" agar cocok dengan User
  readBy User[] @relation("UserReadBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
}

// --- MODEL BARU UNTUK SEJARAH DONASI UANG ---
model FundDonationHistory {
  id String @id @default(cuid())

  // Info Requestor
  requestorFirebaseId String // ID dari Firebase Auth
  donatorName         String // Nama donor
  donatorDateTime     DateTime @default(now()) // Tanggal dan jam donor berdonasi

  // Info Donasi
  amount         Decimal // Jumlah donasi
  paymentProcess String // Jenis pembayaran untuk donasi uang
}
